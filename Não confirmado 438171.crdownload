#----------------------------------------RCALL---------------------------------------#
def rcall(operand, add):
    # destino absoluto
    target = int(operand, 16)
    pc = int(add, 16)

    # calcula deslocamento em palavras (já que cada instrução = 2 bytes)
    n = (target - (pc + 2)) // 2  

    # encoding: 1101 1nnn nnnn nnnn
    opcode = (0b11011 << 11) | (n & 0x7FF)
    opcode = opcode.to_bytes(2, byteorder="little")  # little-endian

    return opcode

#----------------------------------------SLEEP---------------------------------------#
def sleep():
    # encoding: 0000 0000 0000 0011
    opcode = (0b0000000000000011)
    opcode = opcode.to_bytes(2, byteorder="little")  # little-endian

    return opcode

