#-----------------------------------------BOV----------------------------------------#
def bov(operand, add):
    # destino absoluto
    target = int(operand, 16)
    pc = int(add, 16)

    # calcula deslocamento em palavras (já que cada instrução = 2 bytes)
    n = (target - (pc + 2)) // 2  

    # encoding: 1110 0100 nnnn nnnn
    opcode = (0b11100100 << 8) | (n & 0xFF)
    opcode = opcode.to_bytes(2, byteorder="little")  # little-endian

    return opcode

#----------------------------------------CALL----------------------------------------#
def call(operand):
    # Separar os operandos pela vírgula e remover espaços em branco
    parts = [part.strip() for part in operand.split(',')]

    # converte o operando (string hexadecimal) em inteiro
    k = int(parts[0], 16)

    # divide por 2 pois o PC multiplica por 2
    k = k // 2

    if k > 0xFFFFF:
        raise ValueError("Endereço fora do intervalo para GOTO (máx. 0xFFFFF)")
    
    # Inicializa 's' com o valor padrão (0)
    s = 0

    # Verifica se existe uma segunda parte (bit 's')
    if len(parts) > 1:
        s_value_str = parts[1]
        if s_value_str == '0':
            s = 0
        else:
            # Se a segunda parte existir e não for '0', assume-se que 's' é 1
            s = 1

    # 1ª palavra: 1110 110s k7..k0
    word1 = (0b1110110 << 9) | (s << 8) | (k & 0xFF)
    word1 = word1.to_bytes(2, byteorder='little')

    # 2ª palavra: 1111 k19..k8
    word2 = 0xF000 | (k >> 8)
    word2 = word2.to_bytes(2, byteorder='little')

    return word1 + word2

#---------------------------------------CLRWDT---------------------------------------#
def clrwdt():
    # encoding: 0000 0000 0000 0100
    opcode = (0b0000000000000100)
    opcode = opcode.to_bytes(2, byteorder="little")  # little-endian

    return opcode

