#----------------------------------------GOTO----------------------------------------#
def goto(operand):
    # converte o operando (string hexadecimal) em inteiro
    k = int(operand, 16)

    # divide por 2 pois o PC multiplica por 2
    k = k // 2

    if k > 0xFFFFF:
        raise ValueError("Endereço fora do intervalo para GOTO (máx. 0xFFFFF)")

    # 1ª palavra: 1110 1111 k7..k0
    word1 = 0xEF00 | (k & 0xFF)
    word1 = word1.to_bytes(2, byteorder='little')

    # 2ª palavra: 1111 k19..k8
    word2 = 0xF000 | (k >> 8)
    word2 = word2.to_bytes(2, byteorder='little')

    return word1 + word2

#----------------------------------------CLRF----------------------------------------#
def clrf(operand):
    # converte o operando (string hexadecimal) em inteiro
    f = int(operand, 16)

    # verificando se o é para acessar os registradores dentro do Access Bank
    if (f >= 0x000 and f <= 0x07F) or (f >= 0xF80 and f <= 0xFFF):
        a = 0
    else:
        a = 1

    # encoding: 0110 101a ffff ffff
    opcode = (0b0110101 << 9) | (a << 8) | (f & 0xFF)
    opcode = opcode.to_bytes(2, byteorder='little')  # little-endian

    return opcode

#----------------------------------------MOVLW---------------------------------------#
def movlw(operand):
    # converte o operando (string hexadecimal) em inteiro
    k = int(operand, 16)

    # encoding: 0000 1110 kkkk kkkk
    opcode = (0b00001110 << 8) | (k & 0xFF)
    opcode = opcode.to_bytes(2, byteorder='little')  # little-endian

    return opcode

#----------------------------------------MOVWF---------------------------------------#
def movwf(operand):
    # converte o operando (string hexadecimal) em inteiro
    f = int(operand, 16)

    # verificando se o é para acessar os registradores dentro do Access Bank
    if (f >= 0x000 and f <= 0x07F) or (f >= 0xF80 and f <= 0xFFF):
        a = 0
    else:
        a = 1

    # encoding: 0110 111a ffff ffff
    opcode = (0b0110111 << 9) | (a << 8) | (f & 0xFF)
    opcode = opcode.to_bytes(2, byteorder='little')  # little-endian

    return opcode

#----------------------------------------MOVF----------------------------------------#
def movf(operand):
    # separar os operandos pela vírgula e remover espaços em branco
    parts = [part.strip() for part in operand.split(',')]

    # converte o operando (string hexadecimal) em inteiro
    f = int(parts[0], 16)

    # verifica se d = W
    if parts[1] == 'W':
        d = 0
    elif parts[1] == 'F':
        d = 1
    
    # verificando se o é para acessar os registradores dentro do Access Bank
    if (f >= 0x00 and f <= 0x07F) or (f >= 0xF80 and f <= 0xFFF):
        a = 0
    else:
        a = 1

    # encoding: 0101 00da ffff ffff
    opcode = (0b010100 << 10) | (d << 9) | (a << 8) | (f & 0xFF)
    opcode = opcode.to_bytes(2, byteorder='little')  # little-endian

    return opcode

#-----------------------------------------BZ-----------------------------------------#
def bz(operand, add):
    # converte o operando (string hexadecimal) em inteiro
    target = int(operand, 16)
    pc = int(add, 16)

    # deslocamento relativo em instruções
    n = (target - (pc + 2)) // 2

    # encoding: 1110 0000 nnnn nnnn
    opcode = (0b11100000 << 8) | (n & 0xFF)
    opcode = opcode.to_bytes(2, byteorder='little')  # little-endian

    return opcode

#----------------------------------------DECF----------------------------------------#
def decf(operand):
    # separar os operandos pela vírgula e remover espaços em branco
    parts = [part.strip() for part in operand.split(',')]

    # primeiro parâmetro sempre é f
    f = int(parts[0], 16)

    # verifica se d = W
    if parts[1] == 'W':
        d = 0
    elif parts[1] == 'F':
        d = 1
    
    # verificando se o é para acessar os registradores dentro do Access Bank
    if (f >= 0x00 and f <= 0x07F) or (f >= 0xF80 and f <= 0xFFF):
        a = 0
    else:
        a = 1

    # opcode: 0000 01da ffff ffff
    opcode = (0b000001 << 10) | (d << 9) | (a << 8) | (f & 0xFF)
    opcode = opcode.to_bytes(2, byteorder='little')  # little-endian

    return opcode

#---------------------------------------DECFSZ---------------------------------------#
def decfsz(operand):
    # separar operandos por vírgula e remover espaços
    parts = [part.strip() for part in operand.split(',')]

    # primeiro parâmetro: f (endereço do registrador)
    f = int(parts[0], 16)

    # verifica se d = W
    if parts[1] == 'W':
        d = 0
    elif parts[1] == 'F':
        d = 1
    
    # verificando se o é para acessar os registradores dentro do Access Bank
    if (f >= 0x00 and f <= 0x07F) or (f >= 0xF80 and f <= 0xFFF):
        a = 0
    else:
        a = 1

    # opcode: 0010 11da ffff ffff
    opcode = (0b001011 << 10) | (d << 9) | (a << 8) | (f & 0xFF)
    opcode = opcode.to_bytes(2, byteorder='little')  # little-endian

    return opcode

#-----------------------------------------BRA----------------------------------------#
def bra(operand, add):
    # destino absoluto
    target = int(operand, 16)
    pc = int(add, 16)

    # calcula deslocamento em palavras (já que cada instrução = 2 bytes)
    n = (target - (pc + 2)) // 2  

    # encoding: 1101 0nnn nnnn nnnn
    opcode = (0b11010 << 11) | (n & 0x7FF)
    opcode = opcode.to_bytes(2, byteorder="little")  # little-endian

    return opcode

#----------------------------------------RETLW---------------------------------------#
def retlw(operand):
    # converte literal para inteiro
    k = int(operand, 16)

    # encoding: 0000 1100 kkkk kkkk
    opcode = (0b00001100 << 8) | (k & 0xFF)
    opcode = opcode.to_bytes(2, byteorder='little')  # little-endian

    return opcode

#-----------------------------------------BCF----------------------------------------#
def bcf(operand):
    # separar operandos
    parts = [part.strip() for part in operand.split('.')]

    # primeiro parâmetro = f
    f = int(parts[0], 16)

    # segundo parâmetro = b
    b = int(parts[1], 10)

    # verificando se o é para acessar os registradores dentro do Access Bank
    if (f >= 0x00 and f <= 0x07F) or (f >= 0xF80 and f <= 0xFFF):
        a = 0
    else:
        a = 1

    # encoding: 1001 bbba ffff ffff
    opcode = (0b1001 << 12) | ((b & 0b111) << 9) | (a << 8) | (f & 0xFF)
    opcode = opcode.to_bytes(2, byteorder="little")  # little-endian

    return opcode

